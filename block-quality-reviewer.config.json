    "max_global_css_bytes": 20000,
    "max_dom_queries_per_file": 14,
    "max_important_per_file": 5
  },
  "heuristics": {
    "lcp_block_name_pattern": "(hero|banner|teaser|carousel|marquee|promo|splash|intro|feature|spot|homepage|landing|lp-)"
  },
  "rules": {
    "disabled": [],
    "severities": {}
