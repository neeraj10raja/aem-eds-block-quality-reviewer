{
  "max_findings": 30,
  "fail_on_severities": [],
  "include_full_file_when_patch_missing": false,
  "paths": {
    "block_root": "blocks",
    "global_scripts": ["scripts/scripts.js"],
    "aem_library": "scripts/aem.js",
    "global_styles": ["styles/styles.css"],
    "lazy_styles": ["styles/lazy-styles.css"],
    "head": "head.html"
  },
  "thresholds": {
    "max_file_bytes": 1048576,
